{
  "name": "orbit-system-manager",
  "version": "1.0.0",
  "description": "Orbit System Manager - Real-time System Monitoring & 3D Topology",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "build": "rollup -c && node -e \"let h=require('fs').readFileSync('index.html','utf8');h=h.replace('dist/bundle.js','bundle.js');require('fs').writeFileSync('dist/index.html',h);require('fs').cpSync('style.css','dist/style.css')\"",
    "start": "rollup -c -w",
    "dev": "tauri dev",
    "build:app": "npm run build && tauri build"
  },
  "dependencies": {
    "three": "^0.152.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@tauri-apps/cli": "^2.11.2",
    "rollup": "^3.20.0"
  }
}
