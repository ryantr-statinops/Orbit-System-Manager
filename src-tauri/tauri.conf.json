{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Orbit System Manager",
  "version": "0.1.0",
  "identifier": "com.orbit.system-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "Orbit System Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/app"
    ],
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}
